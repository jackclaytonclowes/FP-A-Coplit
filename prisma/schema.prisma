generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  xp            Int       @default(0)
  level         Int       @default(1)
  streakCurrent Int       @default(0)
  streakLongest Int       @default(0)
  lastActiveAt  DateTime?
  streakFreezes Int       @default(1)

  accounts       Account[]
  sessions       Session[]
  progress       LessonProgress[]
  courseProgress CourseProgress[]
  achievements   UserAchievement[]
  moodboard      MoodboardItem[]
  journalEntries JournalEntry[]
  savedRefs      SavedReference[]
  xpEvents       XpEvent[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  courseId    String
  completed   Boolean   @default(false)
  quizScore   Int?
  attempts    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model CourseProgress {
  id           String    @id @default(cuid())
  userId       String
  courseId     String
  started      Boolean   @default(true)
  completed    Boolean   @default(false)
  lessonsTotal Int       @default(0)
  lessonsDone  Int       @default(0)
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Achievement {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  icon        String
  xpReward    Int    @default(0)
  rarity      String @default("common")

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

model XpEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MoodboardItem {
  id         String   @id @default(cuid())
  userId     String
  title      String
  type       String
  imageUrl   String?
  notes      String?
  tags       String   @default("[]")
  collection String?
  sourceUrl  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  content   String
  prompt    String?
  lessonId  String?
  courseId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedReference {
  id          String   @id @default(cuid())
  userId      String
  refType     String
  title       String
  description String?
  imageUrl    String?
  tags        String   @default("[]")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyInspiration {
  id          String  @id @default(cuid())
  date        String  @unique
  type        String
  title       String
  subtitle    String?
  description String
  imageUrl    String?
  tags        String  @default("[]")
  lessonLink  String?
}
